<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="stm32_qca7kprogrammer" />
		<Option makefile_is_custom="1" />
		<Option pch_mode="2" />
		<Option compiler="armelfgcc" />
		<MakeCommands>
			<Build command="make firmware" />
			<CompileFile command="$make -f $makefile $file" />
			<Clean command="make clean" />
			<DistClean command="$make -f $makefile distclean$target" />
			<AskRebuildNeeded command="$make -q" />
			<SilentBuild command="make firmware &gt; $(CMD_NULL)" />
		</MakeCommands>
		<Build>
			<Target title="Release">
				<Option output="build/firmware/stm32_qca7kprogrammer" prefix_auto="0" extension_auto="0" />
				<Option object_output="build/firmware/" />
				<Option type="1" />
				<Option compiler="armelfgcc" />
				<MakeCommands>
					<Build command="make firmware" />
					<CompileFile command="$make -f $makefile $file" />
					<Clean command="make clean" />
					<DistClean command="$make -f $makefile distclean$target" />
					<AskRebuildNeeded command="$make -q" />
					<SilentBuild command="make firmware &gt; $(CMD_NULL)" />
				</MakeCommands>
			</Target>
		</Build>
		<Unit filename="Makefile" />
		<Unit filename="include/common.h" />
		<Unit filename="include/embedded_images.h" />
